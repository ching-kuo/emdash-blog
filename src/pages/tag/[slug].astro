---
import {
	getTerm,
	getEmDashCollection,
	getTermsForEntries,
	decodeSlug,
} from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("tag", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	where: { tag: term.slug },
	orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Single batched query for tags on every post tagged with this term,
// rather than calling getEntryTerms() per post.
const catsByEntry = await getTermsForEntries(
	"posts",
	posts.map((p) => p.data.id),
	"category",
);
const filteredPosts = posts.map((post) => ({
	post,
	categories: catsByEntry.get(post.data.id) ?? [],
}));
---

<Base
	title={`Posts tagged "${term.label}"`}
	description={`All posts tagged with ${term.label}`}
>
	<div class="archive-page">
		<header class="archive-header">
			<span class="archive-eyebrow">Tag</span>
			<h1 class="archive-title">{term.label}</h1>
			<p class="archive-count">
				{filteredPosts.length}
				{filteredPosts.length === 1 ? "post" : "posts"}
			</p>
		</header>

		{
			filteredPosts.length === 0 ? (
				<p class="no-posts">No posts with this tag yet.</p>
			) : (
				<div class="posts-list">
					{filteredPosts.map(({ post, categories }) => {
						const firstCat = categories[0];
						return (
							<PostCard
								title={post.data.title ?? "Untitled"}
								href={`/posts/${post.id}`}
								category={firstCat?.label}
								categoryHref={firstCat ? `/category/${firstCat.slug}` : undefined}
								date={post.data.publishedAt ?? undefined}
								readingTime={getReadingTime(post.data.content)}
								excerpt={post.data.excerpt}
								image={post.data.featured_image}
								bylines={post.data.bylines ?? []}
								layout="row"
							/>
						);
					})}
				</div>
			)
		}
	</div>
</Base>

<style>
	.archive-page {
		max-width: 820px;
		margin: 0 auto;
		padding: var(--space-8) var(--space-6) var(--space-9);
	}

	.archive-header {
		margin-bottom: var(--space-7);
		padding-bottom: var(--space-6);
		border-bottom: var(--border-hairline) solid var(--border);
	}

	.archive-eyebrow {
		display: block;
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: var(--weight-heading);
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
		margin-bottom: var(--space-3);
	}

	.archive-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h1);
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-tight);
		color: var(--text-strong);
		margin: 0 0 var(--space-3);
	}

	.archive-count {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin: 0;
	}

	.no-posts {
		font-family: var(--font-serif);
		font-size: var(--text-lg);
		color: var(--text-muted);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
	}

	@media (max-width: 600px) {
		.archive-page {
			padding: var(--space-6) var(--space-4) var(--space-8);
		}

		.archive-title {
			font-size: var(--text-h2);
		}
	}
</style>
