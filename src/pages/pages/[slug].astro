---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base
	title={page.data.title}
	content={{ collection: "pages", id: page.data.id, slug }}
>
	<article class="static-page">
		<header class="static-header">
			<h1 class="static-title" {...page.edit.title}>{page.data.title}</h1>
		</header>

		<div class="prose static-body">
			<PortableText value={page.data.content} />
		</div>
	</article>
</Base>

<style>
	.static-page {
		max-width: var(--measure);
		margin: 0 auto;
		padding: var(--space-8) var(--space-6) var(--space-9);
	}

	.static-header {
		margin-bottom: var(--space-7);
		padding-bottom: var(--space-6);
		border-bottom: var(--border-hairline) solid var(--border);
	}

	.static-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h1);
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-tight);
		color: var(--text-strong);
		margin: 0;
	}

	/* The .prose class from base.css handles all body typography.
	   Override max-width so it fills the centred column. */
	.static-body {
		max-width: 100%;
	}

	@media (max-width: 600px) {
		.static-page {
			padding: var(--space-6) var(--space-4) var(--space-8);
		}

		.static-title {
			font-size: var(--text-h2);
		}
	}
</style>
