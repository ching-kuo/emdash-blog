---
import {
	getEmDashEntry,
	getEmDashCollection,
	getTermsForEntries,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import { Image, PortableText, Comments, CommentForm, WidgetArea } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import Tag from "../../components/Tag.astro";
import Avatar from "../../components/Avatar.astro";
import Byline from "../../components/Byline.astro";
import SocialLinks from "../../components/SocialLinks.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback. The image may have src (external)
// or meta.storageKey (local).
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http") ? image.src : `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Bylines + tags are already hydrated by getEmDashEntry.
const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);
const tags = post.data.terms?.tag ?? [];
const categoryTerm = (post.data.terms?.category ?? [])[0];
const category = categoryTerm
	? { label: categoryTerm.label, href: `/category/${categoryTerm.slug}` }
	: null;

// Extract a 2-level table of contents from the Portable Text headings.
// ids are heading-{n} in document order; an inline script below assigns the
// same ids to the rendered headings so the anchors + active-tracking line up.
interface TocItem {
	id: string;
	label: string;
	children?: { id: string; label: string }[];
}
function extractToc(blocks: unknown): TocItem[] {
	if (!Array.isArray(blocks)) return [];
	const items: TocItem[] = [];
	let idx = 0;
	for (const b of blocks) {
		if (!b || (b as any)._type !== "block") continue;
		const style = (b as any).style;
		if (style !== "h2" && style !== "h3") continue;
		const label = ((b as any).children ?? [])
			.map((c: any) => c?.text ?? "")
			.join("")
			.trim();
		if (!label) continue;
		const id = `heading-${idx}`;
		idx++;
		if (style === "h3" && items.length) {
			const last = items[items.length - 1];
			(last.children ??= []).push({ id, label });
		} else {
			items.push({ id, label, children: [] });
		}
	}
	return items;
}
const tocItems = extractToc(post.data.content);

// Fetch a few extra recent posts for the "Continue reading" row.
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);
const otherTagsByEntry = await getTermsForEntries(
	"posts",
	otherPosts.map((p) => p.data.id),
	"tag"
);
const otherPostsWithTags = otherPosts.map((p) => {
	const t = (otherTagsByEntry.get(p.data.id) ?? [])[0];
	return { post: p, category: t ? { label: t.label, href: `/tag/${t.slug}` } : null };
});

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
const headerMeta = [publishDate, `${readingTime} min read`].filter(Boolean).join(" · ");

// Lead author for the closing author block.
const leadByline = bylines[0]?.byline ?? null;
const leadRole = bylines[0]?.roleLabel ?? null;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="article">
		<header class="article-head">
			<div class="article-meta">
				{category && <Tag href={category.href} size="sm">{category.label}</Tag>}
				{headerMeta && <span class="article-date">{headerMeta}</span>}
			</div>
			<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
			{
				post.data.excerpt && (
					<p class="article-excerpt" {...post.edit.excerpt}>
						{post.data.excerpt}
					</p>
				)
			}
			{
				bylines.length > 0 && (
					<div class="article-byline">
						<Byline bylines={bylines} size={28} max={3} showRoles />
					</div>
				)
			}
		</header>

		{
			post.data.featured_image && (
				<div class="article-hero" {...post.edit.featured_image}>
					<Image image={post.data.featured_image} />
				</div>
			)
		}

		<div class="article-grid">
			<div class="article-body prose">
				<PortableText value={post.data.content} />
			</div>

			<aside class="article-rail">
				<div class="rail-sticky">
					<TableOfContents items={tocItems} title="目錄" />
					<div class="rail-widgets">
						<WidgetArea name="sidebar" />
					</div>
				</div>
			</aside>
		</div>

		{
			tags.length > 0 && (
				<div class="article-tags">
					<span class="article-tags-label">Tags</span>
					<div class="article-tags-list">
						{tags.map((t) => (
							<Tag href={`/tag/${t.slug}`} variant="muted" size="sm">
								{t.label}
							</Tag>
						))}
					</div>
				</div>
			)
		}

		{
			leadByline && (
				<section class="author-block">
					<Avatar
						name={leadByline.displayName}
						src={
							leadByline.avatarMediaId
								? `/_emdash/api/media/file/${leadByline.avatarMediaId}`
								: undefined
						}
						size="lg"
					/>
					<div class="author-body">
						<p class="author-name">{leadByline.displayName}</p>
						{leadRole && <p class="author-role">{leadRole}</p>}
						{siteTagline && <p class="author-bio">{siteTagline}</p>}
						<SocialLinks size={34} />
					</div>
				</section>
			)
		}

		<div class="article-comments">
			<Comments collection="posts" contentId={post.data.id} threaded />
			<CommentForm collection="posts" contentId={post.data.id} />
		</div>
	</article>

	{
		otherPostsWithTags.length > 0 && (
			<section class="more-posts">
				<div class="more-inner">
					<h2 class="more-title">Continue reading</h2>
					<div class="more-grid">
						{otherPostsWithTags.map(({ post: p, category: cat }) => (
							<PostCard
								title={p.data.title ?? "Untitled"}
								href={`/posts/${p.id}`}
								category={cat?.label}
								categoryHref={cat?.href}
								date={p.data.publishedAt ?? undefined}
								readingTime={getReadingTime(p.data.content)}
								excerpt={p.data.excerpt}
								image={p.data.featured_image}
								bylines={p.data.bylines ?? []}
								layout="stacked"
							/>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* Assign heading-{n} ids in document order; runs during parse, before the
	    TableOfContents module script's observer (deferred). */}
	<script is:inline define:vars={{ count: tocItems.length }}>
		(function () {
			if (!count) return;
			const hs = document.querySelectorAll(".article-body h2, .article-body h3");
			// Number only non-empty headings, matching extractToc's indexing.
			let i = 0;
			hs.forEach((h) => {
				if (!h.textContent || !h.textContent.trim()) return;
				if (!h.id) h.id = "heading-" + i;
				i++;
			});
		})();
	</script>
</Base>

<style>
	.article {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--space-7) var(--space-6) 0;
	}

	/* Header (centred on the reading measure) */
	.article-head {
		max-width: var(--measure);
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
		flex-wrap: wrap;
	}

	.article-date {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.article-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h1);
		line-height: 1.18;
		letter-spacing: var(--tracking-tight);
		color: var(--text-strong);
		margin: 0;
	}

	.article-excerpt {
		font-family: var(--font-serif);
		font-size: var(--text-lg);
		line-height: 1.6;
		color: var(--text-muted);
		margin: var(--space-4) 0 0;
	}

	.article-byline {
		margin: var(--space-5) 0 0;
	}

	/* Hero */
	.article-hero {
		max-width: var(--measure-wide);
		margin: var(--space-6) 0 var(--space-7);
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--bg-deep);
	}

	.article-hero :global(img) {
		width: 100%;
		height: auto;
		max-height: 480px;
		object-fit: cover;
		display: block;
	}

	/* Body + TOC rail */
	.article-grid {
		display: grid;
		grid-template-columns: minmax(0, var(--measure-wide)) 1fr;
		gap: var(--space-8);
		align-items: start;
	}

	.article-body {
		min-width: 0;
		max-width: var(--measure-wide);
	}

	.article-body :global(h2),
	.article-body :global(h3) {
		scroll-margin-top: calc(var(--header-height) + 1rem);
	}

	.article-rail {
		min-width: 0;
	}

	.rail-sticky {
		position: sticky;
		top: calc(var(--header-height) + var(--space-5));
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	.rail-widgets :global(.widget-area) {
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
	}

	.rail-widgets :global(.widget__title) {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
		font-weight: var(--weight-heading);
		color: var(--text-faint);
		margin-bottom: var(--space-2);
	}

	/* Author block */
	.author-block {
		max-width: var(--measure-wide);
		margin: var(--space-8) 0 0;
		background: var(--surface-raised);
		border-radius: var(--radius-lg);
		padding: var(--space-6);
		display: flex;
		gap: var(--space-5);
		align-items: flex-start;
	}

	.author-name {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-lg);
		color: var(--text-strong);
		margin: 0;
	}

	.author-role {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin: 2px 0 0;
	}

	.article-tags {
		max-width: var(--measure-wide);
		display: flex;
		align-items: baseline;
		gap: var(--space-4);
		flex-wrap: wrap;
		margin-top: var(--space-7);
		padding-top: var(--space-5);
		border-top: var(--border-hairline) solid var(--border);
	}

	.article-tags-label {
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
		font-weight: var(--weight-heading);
		color: var(--text-faint);
	}

	.article-tags-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.author-bio {
		font-family: var(--font-serif);
		font-size: var(--text-base);
		line-height: 1.7;
		color: var(--text-muted);
		margin: var(--space-2) 0 var(--space-4);
	}

	/* Comments */
	.article-comments {
		max-width: var(--measure-wide);
		margin-top: var(--space-8);
		padding-top: var(--space-7);
		border-top: var(--border-hairline) solid var(--border);
	}

	.article-comments :global(.ec-comments-heading) {
		font-family: var(--font-serif);
		font-size: var(--text-h3);
		font-weight: var(--weight-heading);
		margin-bottom: var(--space-6);
	}

	/* Continue reading */
	.more-posts {
		background: var(--bg-deep);
		border-top: var(--border-hairline) solid var(--border);
		margin-top: var(--space-9);
		padding: var(--space-8) 0;
	}

	.more-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--space-6);
	}

	.more-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h3);
		color: var(--text-strong);
		margin: 0 0 var(--space-6);
	}

	.more-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-7);
	}

	/* The stacked cards in the grid shouldn't carry the row divider */
	.more-grid :global(.post-card) {
		border-bottom: none;
		padding: 0;
	}

	@media (max-width: 1080px) {
		.article-grid {
			grid-template-columns: minmax(0, 1fr);
			gap: 0;
		}
		.article-rail {
			display: none;
		}
		.more-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.article-title {
			font-size: var(--text-h2);
		}
		.more-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
