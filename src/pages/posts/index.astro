---
import { getEmDashCollection, getTermsForEntries } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

// Sort in the database rather than in JS — lets the DB use its index on
// published_at and avoids a full-table scan on the client.
const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Single batched query for tags across all posts, instead of one
// getEntryTerms() call per post (which would be N round-trips).
// Bylines are already hydrated on entry.data.bylines.
// Chip = primary category (links to /category); tags remain navigable via
// /tag pages and the article tag row.
const catsByEntry = await getTermsForEntries(
	"posts",
	posts.map((p) => p.data.id),
	"category",
);

const postsWithCats = posts.map((post) => ({
	post,
	categories: catsByEntry.get(post.data.id) ?? [],
	bylines: post.data.bylines ?? [],
}));
---

<Base title="All Posts" description="Browse all blog posts">
	<div class="posts-page">
		<header class="page-header">
			<h1 class="page-title">All Posts</h1>
			<p class="page-count">
				{posts.length}
				{posts.length === 1 ? "article" : "articles"}
			</p>
		</header>

		{
			posts.length === 0 ? (
				<p class="empty">No posts yet.</p>
			) : (
				<div class="posts-list">
					{postsWithCats.map(({ post, categories, bylines }) => {
						const firstCat = categories[0];
						return (
							<PostCard
								title={post.data.title ?? "Untitled"}
								href={`/posts/${post.id}`}
								category={firstCat?.label}
								categoryHref={firstCat ? `/category/${firstCat.slug}` : undefined}
								date={post.data.publishedAt ?? undefined}
								readingTime={getReadingTime(post.data.content)}
								excerpt={post.data.excerpt}
								image={post.data.featured_image}
								bylines={bylines}
								layout="row"
							/>
						);
					})}
				</div>
			)
		}
	</div>
</Base>

<style>
	.posts-page {
		max-width: 820px;
		margin: 0 auto;
		padding: var(--space-8) var(--space-6) var(--space-9);
	}

	.page-header {
		margin-bottom: var(--space-7);
	}

	.page-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-bold);
		font-size: var(--text-h1);
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-tight);
		color: var(--text-strong);
		margin: 0 0 var(--space-3);
	}

	.page-count {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin: 0;
	}

	.empty {
		font-family: var(--font-serif);
		font-size: var(--text-lg);
		color: var(--text-muted);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
	}

	@media (max-width: 600px) {
		.posts-page {
			padding: var(--space-6) var(--space-4) var(--space-8);
		}

		.page-title {
			font-size: var(--text-h2);
		}
	}
</style>
