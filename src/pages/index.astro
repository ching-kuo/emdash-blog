---
import { getEmDashCollection, getTermsForEntries, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import Tag from "../components/Tag.astro";
import Button from "../components/Button.astro";
import Byline from "../components/Byline.astro";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

// Limit to what we render (1 featured + 6 feed). The DB does the slicing
// instead of fetching every post and discarding the tail in JS.
const POSTS_PER_PAGE = 7;

const [{ entries: posts, cacheHint }, settings] = await Promise.all([
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: POSTS_PER_PAGE + 1, // +1 to detect "view all" need
	}),
	getSiteSettings(),
]);
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(settings);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const visiblePosts = posts.slice(0, POSTS_PER_PAGE);
const hasMorePosts = posts.length > POSTS_PER_PAGE;

// Hero = first post with a featured image; the rest fill the feed.
const featuredPost = visiblePosts.find((p) => p.data.featured_image);
const featuredIndex = featuredPost ? visiblePosts.indexOf(featuredPost) : -1;
const gridPosts = visiblePosts.filter((_, i) => i !== featuredIndex).slice(0, 6);

// One batched query for the topic chip (first tag) across featured + feed.
const tagEntryIds = [
	...(featuredPost ? [featuredPost.data.id] : []),
	...gridPosts.map((p) => p.data.id),
];
// Chip = the post's primary category (links to /category); tags stay
// navigable via /tag pages and the article's tag row.
const catsByEntry = await getTermsForEntries("posts", tagEntryIds, "category");
function firstCategory(id: string) {
	const t = (catsByEntry.get(id) ?? [])[0];
	return t ? { label: t.label, href: `/category/${t.slug}` } : null;
}

function fmtDate(d: Date | null | undefined) {
	return d
		? d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
		: null;
}

const featuredCat = featuredPost ? firstCategory(featuredPost.data.id) : null;
const featuredBylines = featuredPost?.data.bylines ?? [];
const featuredMeta = featuredPost
	? [fmtDate(featuredPost.data.publishedAt), `${getReadingTime(featuredPost.data.content)} min`]
			.filter(Boolean)
			.join(" · ")
	: "";
---

<Base title={siteTitle} description={siteTagline}>
	{
		posts.length === 0 ? (
			<section class="empty-state">
				<h2>No posts yet</h2>
				<p>Create your first post in the admin panel.</p>
				<Button href="/_emdash/admin/content/posts/new">Create a post</Button>
			</section>
		) : (
			<div class="home">
				<header class="lede">
					<h1 class="lede-title">{siteTitle}</h1>
					{siteTagline && <p class="lede-sub">{siteTagline}</p>}
				</header>

				{featuredPost && (
					<article class="featured">
						<div class="featured-text">
							<div class="featured-meta">
								{featuredCat && (
									<Tag href={featuredCat.href} size="sm">
										{featuredCat.label}
									</Tag>
								)}
								{featuredBylines.length > 0 && (
									<Byline bylines={featuredBylines} size={22} max={2} />
								)}
								{featuredMeta && <span class="featured-date">{featuredMeta}</span>}
							</div>
							<a href={`/posts/${featuredPost.id}`} class="featured-title-link">
								<h2 class="featured-title">{featuredPost.data.title}</h2>
							</a>
							{featuredPost.data.excerpt && (
								<p class="featured-excerpt">{featuredPost.data.excerpt}</p>
							)}
							<Button href={`/posts/${featuredPost.id}`} variant="secondary">
								繼續閱讀 →
							</Button>
						</div>
						<a
							href={`/posts/${featuredPost.id}`}
							class="featured-thumb"
							aria-hidden="true"
							tabindex="-1"
						>
							<Image image={featuredPost.data.featured_image} />
						</a>
					</article>
				)}

				{gridPosts.length > 0 && (
					<section class="feed">
						<header class="feed-head">
							<h2 class="feed-title">Latest</h2>
							{hasMorePosts && (
								<a href="/posts" class="feed-link">
									View all →
								</a>
							)}
						</header>
						{gridPosts.map((post) => {
							const cat = firstCategory(post.data.id);
							return (
								<PostCard
									title={post.data.title ?? "Untitled"}
									href={`/posts/${post.id}`}
									category={cat?.label}
									categoryHref={cat?.href}
									date={post.data.publishedAt ?? undefined}
									readingTime={getReadingTime(post.data.content)}
									excerpt={post.data.excerpt}
									image={post.data.featured_image}
									bylines={post.data.bylines ?? []}
									layout="row"
								/>
							);
						})}
					</section>
				)}
			</div>
		)
	}
</Base>

<style>
	.home {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--space-8) var(--space-6) 0;
	}

	/* Lede */
	.lede {
		max-width: var(--measure);
		margin-bottom: var(--space-8);
	}

	.lede-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h1);
		line-height: 1.15;
		letter-spacing: var(--tracking-tight);
		color: var(--text-strong);
		margin: 0;
	}

	.lede-sub {
		font-family: var(--font-serif);
		font-size: var(--text-lg);
		line-height: 1.7;
		color: var(--text-muted);
		margin: var(--space-4) 0 0;
	}

	/* Featured */
	.featured {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: var(--space-7);
		align-items: center;
		padding-bottom: var(--space-7);
		border-bottom: var(--border-hairline) solid var(--border);
	}

	.featured-meta {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
		flex-wrap: wrap;
	}

	.featured-date {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.featured-title-link {
		text-decoration: none;
	}

	.featured-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h2);
		line-height: var(--leading-snug);
		color: var(--text-strong);
		margin: 0;
		transition: color var(--dur-fast) var(--ease-out);
	}

	.featured-title-link:hover .featured-title {
		color: var(--accent);
	}

	.featured-excerpt {
		font-family: var(--font-serif);
		font-size: var(--text-prose);
		line-height: 1.7;
		color: var(--text-muted);
		margin: var(--space-4) 0 var(--space-5);
	}

	.featured-thumb {
		display: block;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--bg-deep);
		aspect-ratio: 16 / 11;
	}

	.featured-thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--dur-slow) var(--ease-out);
	}

	.featured:hover .featured-thumb :global(img) {
		transform: scale(1.03);
	}

	/* Feed */
	.feed {
		max-width: 820px;
		margin-top: var(--space-7);
	}

	.feed-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--space-2);
	}

	.feed-title {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: var(--weight-heading);
		text-transform: uppercase;
		letter-spacing: var(--tracking-label);
		color: var(--text-muted);
	}

	.feed-link {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--accent);
		text-decoration: none;
	}

	.feed-link:hover {
		color: var(--accent-strong);
	}

	/* Empty state */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-3);
		text-align: center;
		padding: var(--space-9) var(--space-6);
		max-width: 420px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-family: var(--font-serif);
		font-size: var(--text-h3);
	}

	.empty-state p {
		color: var(--text-muted);
	}

	@media (max-width: 860px) {
		.featured {
			grid-template-columns: 1fr;
			gap: var(--space-5);
		}
		.featured-thumb {
			order: -1;
		}
	}
</style>
