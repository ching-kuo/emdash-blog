---
/*
  SocialLinks -- footer / about-block icon links. Ported from the design
  system's SocialLinks.jsx. Brand glyphs (Facebook, GitHub, Twitter/X) plus
  RSS and a generic-link fallback, single-path `fill: currentColor`.

  Pass `links` ([{ href, type?, label? }]); when `type` is omitted it is
  detected from the href hostname, so an EmDash `social` menu can be piped
  straight in. Defaults to Gene's own links when nothing is passed.

  ponytail: icon set is the handful a personal blog needs -- add a path to
  ICONS and a branch to detectType() if a new platform shows up.
*/
interface SocialLink {
	href: string;
	type?: string;
	label?: string;
}
interface Props {
	links?: SocialLink[];
	size?: number;
	class?: string;
}
const {
	links = [
		{ type: "facebook", href: "https://www.facebook.com/groups/cloudnative.tw/" },
		{ type: "github", href: "https://github.com/ching-kuo" },
		{ type: "twitter", href: "https://twitter.com/iGeneKuo" },
	],
	size = 38,
	class: className,
} = Astro.props;

function detectType(href: string): string {
	const lower = href.toLowerCase();
	if (lower.startsWith("mailto:")) return "email";
	let host = "";
	try {
		host = new URL(href).hostname.replace(/^www\./, "");
	} catch {
		host = "";
	}
	if (host.includes("github")) return "github";
	if (host === "x.com" || host.endsWith(".x.com") || host.includes("twitter")) return "twitter";
	if (host.includes("facebook")) return "facebook";
	if (lower.includes("rss") || lower.endsWith(".xml")) return "rss";
	return "link";
}

const LABELS: Record<string, string> = {
	facebook: "Facebook",
	github: "GitHub",
	twitter: "Twitter / X",
	rss: "RSS",
	email: "Email",
	link: "Link",
};

// Single-path icons (24x24). fill:currentColor for brand glyphs; the generic
// "link" and "email" use stroke so they read as line icons.
const ICONS: Record<string, { d: string; stroke?: boolean }> = {
	facebook: {
		d: "M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.9h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94Z",
	},
	github: {
		d: "M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.03 10.03 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z",
	},
	twitter: {
		d: "M18.9 2H22l-7.5 8.58L23 22h-6.9l-5.4-7.06L4.5 22H1.4l8.02-9.17L1 2h7.07l4.88 6.45L18.9 2Zm-1.2 18h1.9L7.4 4H5.36L17.7 20Z",
	},
	rss: {
		d: "M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36ZM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44ZM4 10.1A9.9 9.9 0 0 1 13.9 20h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z",
	},
	email: {
		d: "M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm0 2v.4l9 5.6 9-5.6V7H3Z",
	},
	link: {
		stroke: true,
		d: "M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1m1 6a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1",
	},
};

const resolved = links
	.filter((l) => l && l.href)
	.map((l) => {
		const type = l.type ?? detectType(l.href);
		return { ...l, type, icon: ICONS[type] ?? ICONS.link, label: l.label ?? LABELS[type] ?? "Link" };
	});
const isExternal = (href: string) => /^https?:\/\//i.test(href);
---

<div class:list={["social-links", className]} style={`--icon-size:${size}px`}>
	{
		resolved.map((l) => (
			<a
				href={l.href}
				aria-label={l.label}
				title={l.label}
				target={isExternal(l.href) ? "_blank" : undefined}
				rel={isExternal(l.href) ? "noreferrer noopener" : undefined}
			>
				<svg
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill={l.icon.stroke ? "none" : "currentColor"}
					stroke={l.icon.stroke ? "currentColor" : undefined}
					stroke-width={l.icon.stroke ? "2" : undefined}
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d={l.icon.d} />
				</svg>
			</a>
		))
	}
</div>

<style>
	.social-links {
		display: flex;
		gap: var(--space-3);
		flex-wrap: wrap;
	}

	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: var(--icon-size);
		height: var(--icon-size);
		border-radius: var(--radius-md);
		border: var(--border-hairline) solid var(--border);
		background: transparent;
		color: var(--text-muted);
		text-decoration: none;
		transition:
			background var(--dur-fast) var(--ease-out),
			color var(--dur-fast) var(--ease-out);
	}

	.social-links a:hover {
		background: var(--accent-soft);
		color: var(--accent);
	}
</style>
