---
/*
  PostCard -- homepage / archive list item, redesigned to the "Gene WorkSpace"
  editorial style: category chip, title, date + reading time, excerpt, optional
  thumbnail. `layout="row"` puts the thumbnail beside the text; "stacked" puts
  it on top. The thumbnail is an EmDash MediaValue rendered through the
  optimizing <Image>. Pages map their query results onto these props.

  Author bylines (overlapping avatars + names) render in the meta row when
  provided -- pass `post.data.bylines`.
*/
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";
import Tag from "./Tag.astro";
import Byline from "./Byline.astro";

interface Props {
	title: string;
	href: string;
	category?: string | null;
	categoryHref?: string | null;
	date?: Date | string | null;
	readingTime?: number | string | null;
	excerpt?: string | null;
	image?: MediaValue | string | null;
	bylines?: ContentBylineCredit[];
	layout?: "row" | "stacked";
	class?: string;
}
const {
	title,
	href,
	category,
	categoryHref,
	date,
	readingTime,
	excerpt,
	image,
	bylines = [],
	layout = "row",
	class: className,
} = Astro.props;

const dateLabel =
	date instanceof Date
		? date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
		: (date ?? null);
const readingLabel =
	typeof readingTime === "number" ? `${readingTime} min` : (readingTime ?? null);
const meta = [dateLabel, readingLabel].filter(Boolean).join(" · ");
---

<article class:list={["post-card", `post-card--${layout}`, className]}>
	<div class="post-card-body">
		<div class="post-card-meta">
			{category && <Tag href={categoryHref ?? undefined} size="sm">{category}</Tag>}
			{bylines.length > 0 && <Byline bylines={bylines} size={20} />}
			{meta && <span class="post-card-date">{meta}</span>}
		</div>

		<a href={href} class="post-card-title-link">
			<h3 class="post-card-title">{title}</h3>
		</a>

		{excerpt && <p class="post-card-excerpt">{excerpt}</p>}
	</div>

	{
		image && (
			<a href={href} class="post-card-thumb" aria-hidden="true" tabindex="-1">
				<Image image={image} />
			</a>
		)
	}
</article>

<style>
	.post-card {
		display: flex;
		gap: var(--space-5);
		padding: var(--space-5) 0;
		border-bottom: var(--border-hairline) solid var(--border);
	}

	.post-card--row {
		flex-direction: row;
		align-items: flex-start;
	}

	.post-card--stacked {
		flex-direction: column;
		align-items: stretch;
	}

	.post-card-body {
		flex: 1;
		min-width: 0;
	}

	.post-card-meta {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-3);
		flex-wrap: wrap;
	}

	.post-card-date {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.post-card-title-link {
		text-decoration: none;
	}

	.post-card-title {
		font-family: var(--font-serif);
		font-weight: var(--weight-heading);
		font-size: var(--text-h3);
		line-height: var(--leading-snug);
		color: var(--text-strong);
		margin: 0;
		transition: color var(--dur-fast) var(--ease-out);
	}

	.post-card:hover .post-card-title {
		color: var(--accent);
	}

	.post-card-excerpt {
		font-family: var(--font-serif);
		font-size: var(--text-prose); /* design's --text-body (size) */
		line-height: 1.7;
		color: var(--text-muted);
		margin: var(--space-3) 0 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card-thumb {
		display: block;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--bg-deep);
	}

	.post-card--row .post-card-thumb {
		flex: none;
		order: 2;
		width: 168px;
		height: 120px;
	}

	.post-card--stacked .post-card-thumb {
		order: 0;
		width: 100%;
		height: 200px;
		margin-bottom: var(--space-4);
	}

	.post-card-thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--dur-slow) var(--ease-out);
	}

	.post-card:hover .post-card-thumb :global(img) {
		transform: scale(1.04);
	}

	@media (max-width: 640px) {
		.post-card--row {
			flex-direction: column;
		}
		.post-card--row .post-card-thumb {
			order: 0;
			width: 100%;
			height: 200px;
			margin-bottom: var(--space-4);
		}
	}
</style>
