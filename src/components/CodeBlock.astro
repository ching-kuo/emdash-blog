---
/*
  CodeBlock -- code / YAML / shell panel with a header (language label or
  filename + copy button) and horizontal scroll. Ported from the design
  system's CodeBlock.jsx. Pass `code` or default-slot the code text.
*/
interface Props {
	code?: string;
	language?: string;
	filename?: string;
	showCopy?: boolean;
	class?: string;
}
const { code = "", language = "", filename, showCopy = true, class: className } = Astro.props;
const hasHeader = !!(filename || language || showCopy);
const label = filename || language || "";
---

<div class:list={["code-block", className]}>
	{
		hasHeader && (
			<div class="code-head">
				<span class="code-label">{label}</span>
				{showCopy && (
					<button
						type="button"
						class="code-copy"
						data-copy-label="複製"
						data-copied-label="已複製"
					>
						複製
					</button>
				)}
			</div>
		)
	}
	<pre><code><slot>{code}</slot></code></pre>
</div>

<style>
	.code-block {
		background: var(--surface-code);
		border: var(--border-hairline) solid var(--border);
		border-radius: var(--radius-md);
		overflow: hidden;
		font-family: var(--font-mono);
		max-width: var(--measure-wide);
	}

	.code-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.5rem 0.85rem;
		border-bottom: var(--border-hairline) solid var(--border);
		background: color-mix(in oklab, var(--surface-code) 70%, var(--bg));
	}

	.code-label {
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}

	.code-copy {
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		color: var(--text-muted);
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.1rem 0.3rem;
		transition: color var(--dur-fast) var(--ease-out);
	}

	.code-copy:hover {
		color: var(--text-body);
	}

	.code-copy.is-copied {
		color: var(--success);
	}

	.code-block pre {
		margin: 0;
		padding: 1rem 1.1rem;
		overflow-x: auto;
		font-size: 0.9rem;
		line-height: var(--leading-code);
		color: var(--text-code);
	}

	.code-block pre code {
		font-family: inherit;
		background: none;
		padding: 0;
	}
</style>

<script>
	// One delegated listener handles every CodeBlock on the page.
	document.addEventListener("click", (e) => {
		if (!(e.target instanceof Element)) return;
		const btn = e.target.closest<HTMLButtonElement>(".code-copy");
		if (!btn) return;
		const text = btn.closest(".code-block")?.querySelector("pre")?.innerText ?? "";
		if (!navigator.clipboard) return;
		navigator.clipboard.writeText(text).then(() => {
			const copied = btn.dataset.copiedLabel || "Copied";
			const original = btn.dataset.copyLabel || "Copy";
			btn.textContent = copied;
			btn.classList.add("is-copied");
			setTimeout(() => {
				btn.textContent = original;
				btn.classList.remove("is-copied");
			}, 1400);
		});
	});
</script>
