---
import { getMenu, getEmDashCollection, getSiteSettings } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd, WidgetArea } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import { Font } from "astro:assets";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import Avatar from "../components/Avatar.astro";
import SocialLinks from "../components/SocialLinks.astro";
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/theme.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;
const { siteTitle, siteTagline, siteLogo } = resolveBlogSiteIdentity(await getSiteSettings());
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

// Fetch primary menu defined in seed
const menu = await getMenu("primary");

// Optional "social" menu. If a site defines a `social` menu in its seed, its
// items render as brand-icon links in the footer about block. Otherwise the
// SocialLinks component falls back to its built-in defaults.
const socialMenu = await getMenu("social");

// Fetch pages for the footer Navigate column
const { entries: pages } = await getEmDashCollection("pages");

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;

// Wordmark: render the part after the first space in the accent colour
// (e.g. "Gene's" + accent "Workspace"). Falls back to the plain title.
const brand = siteTitle.trim();
const splitAt = brand.indexOf(" ");
const brandLead = splitAt === -1 ? brand : brand.slice(0, splitAt);
const brandRest = splitAt === -1 ? "" : brand.slice(splitAt);

const footerSocial = (socialMenu?.items ?? []).map((item) => ({
	href: item.url,
	label: item.label,
}));
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={Astro.currentLocale ?? "zh-TW"}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<Font cssVariable="--font-serif" preload />
		<Font cssVariable="--font-sans" preload />
		<Font cssVariable="--font-mono" />
		{/* TC companions (zh-TW). Not preloaded: CJK files are large, load on demand. */}
		<Font cssVariable="--font-serif-tc" />
		<Font cssVariable="--font-sans-tc" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<script is:inline>
			// Apply theme before paint (no flash). Records the preference
			// (light / dark / system) on the root for the toggle's icon state.
			(function () {
				var root = document.documentElement;
				var m = document.cookie.match(/(?:^|; )theme=(dark|light)/);
				var pref = m ? m[1] : "system";
				var dark =
					pref === "dark" ||
					(pref === "system" &&
						window.matchMedia("(prefers-color-scheme: dark)").matches);
				root.classList.add(dark ? "dark" : "light");
				root.dataset.themePref = pref;
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header">
			<div class="header-inner">
				<a href="/" class="wordmark" aria-label={siteTitle}>
					{
						siteLogo ? (
							<img
								src={siteLogo.url}
								alt={siteLogo.alt || siteTitle}
								class="wordmark-logo"
							/>
						) : (
							<span class="wordmark-name">
								{brandLead}
								{brandRest && <span class="wordmark-accent">{brandRest}</span>}
							</span>
						)
					}
					{siteTagline && <span class="wordmark-tagline">{siteTagline}</span>}
				</a>

				<nav class="site-nav" aria-label="Primary">
					<ul class="nav-list">
						{
							menu?.items.map((item) => (
								<li>
									<a href={item.url} target={item.target}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>

					<LiveSearch
						placeholder="Search…"
						class="site-search"
						inputClass="site-search-input"
						resultsClass="site-search-results"
						resultClass="site-search-result"
						collections={["posts", "pages"]}
					/>

					<button
						type="button"
						class="theme-toggle"
						aria-label="Switch colour theme (light / dark / system)"
						title="Theme: light / dark / system"
					>
						<svg
							class="ic-sun"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
							><circle cx="12" cy="12" r="4"></circle><path
								d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
							></path></svg
						>
						<svg
							class="ic-moon"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg
						>
						<svg
							class="ic-monitor"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
							><rect x="2" y="3" width="20" height="14" rx="2"></rect><path
								d="M8 21h8M12 17v4"></path></svg
						>
					</button>
					{
						isLoggedIn && (
							<a href="/_emdash/admin" class="nav-admin">
								Admin
							</a>
						)
					}
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-about">
					<Avatar name={siteTitle} src={siteLogo?.url} size="lg" />
					<div class="footer-about-body">
						<p class="footer-about-title">About This Blog</p>
						{siteTagline && <p class="footer-bio">{siteTagline}</p>}
						<SocialLinks
							links={footerSocial.length ? footerSocial : undefined}
							size={36}
						/>
					</div>
				</div>
				<nav class="footer-nav" aria-label="Footer">
					<p class="footer-nav-label">Navigate</p>
					<a href="/">Home</a>
					<a href="/posts">All Posts</a>
					{
						pages.slice(0, 3).map((page) => (
							<a href={`/pages/${page.data.slug || page.id}`}>{page.data.title}</a>
						))
					}
					<a href="/rss.xml">RSS</a>
				</nav>
				<div class="footer-widgets">
					<WidgetArea name="footer" />
				</div>
			</div>
			<div class="footer-bottom">
				<div class="footer-bottom-inner">
					<span>© {year} {siteTitle}</span>
					<span>Powered by <a href="https://emdashcms.com">EmDash</a></span>
				</div>
			</div>
		</footer>

		<script>
			// Theme toggle: cycle system -> light -> dark -> system. Persists an
			// explicit choice to a cookie; "system" clears it and follows the OS.
			const root = document.documentElement;
			const ORDER = ["system", "light", "dark"] as const;
			type Pref = (typeof ORDER)[number];

			function setCookie(value: string) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (value) {
					document.cookie = `theme=${value}; path=/; max-age=31536000; SameSite=Lax${secure}`;
				} else {
					document.cookie = `theme=; path=/; max-age=0; SameSite=Lax${secure}`;
				}
			}

			function apply(pref: Pref) {
				root.dataset.themePref = pref;
				const dark =
					pref === "dark" ||
					(pref === "system" &&
						window.matchMedia("(prefers-color-scheme: dark)").matches);
				root.classList.toggle("dark", dark);
				root.classList.toggle("light", !dark);
				setCookie(pref === "system" ? "" : pref);
			}

			document.querySelector(".theme-toggle")?.addEventListener("click", () => {
				const current = (root.dataset.themePref as Pref) ?? "system";
				apply(ORDER[(ORDER.indexOf(current) + 1) % ORDER.length]);
			});

			// Follow OS changes while preference is "system".
			window
				.matchMedia("(prefers-color-scheme: dark)")
				.addEventListener("change", (e) => {
					if ((root.dataset.themePref ?? "system") === "system") {
						root.classList.toggle("dark", e.matches);
						root.classList.toggle("light", !e.matches);
					}
				});
		</script>

		<script>
			// ⌘K / Ctrl+K focuses the header search.
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
					e.preventDefault();
					document.querySelector<HTMLInputElement>(".site-search-input")?.focus();
				}
			});
		</script>

		<style>
			/* ---------------- Header ---------------- */
			.site-header {
				position: sticky;
				top: 0;
				z-index: 20;
				background: color-mix(in oklab, var(--bg) 86%, transparent);
				backdrop-filter: saturate(140%) blur(10px);
				-webkit-backdrop-filter: saturate(140%) blur(10px);
				border-bottom: var(--border-hairline) solid var(--border);
			}

			.header-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 var(--space-6);
				min-height: var(--header-height);
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: var(--space-5);
			}

			.wordmark {
				display: flex;
				flex-direction: column;
				gap: 2px;
				text-decoration: none;
			}

			.wordmark-name {
				font-family: var(--font-serif);
				font-weight: var(--weight-heading);
				font-size: var(--text-h3);
				line-height: 1;
				letter-spacing: var(--tracking-tight);
				color: var(--text-strong);
			}

			.wordmark-accent {
				color: var(--accent);
			}

			.wordmark-logo {
				height: 40px;
				width: auto;
				display: block;
			}

			.wordmark-tagline {
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				font-weight: var(--weight-semibold);
				letter-spacing: var(--tracking-label);
				text-transform: uppercase;
				color: var(--text-muted);
			}

			.site-nav {
				display: flex;
				align-items: center;
				gap: var(--space-5);
			}

			.nav-list {
				display: flex;
				align-items: center;
				gap: var(--space-5);
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.nav-list a {
				font-family: var(--font-sans);
				font-size: var(--text-base);
				font-weight: var(--weight-medium);
				color: var(--text-body);
				text-decoration: none;
				transition: color var(--dur-fast) var(--ease-out);
			}

			.nav-list a:hover {
				color: var(--accent);
			}

			.nav-admin {
				font-family: var(--font-sans);
				font-size: var(--text-sm);
				color: var(--text-muted);
				text-decoration: none;
			}

			.nav-admin:hover {
				color: var(--text-body);
			}

			/* Header search (EmDash LiveSearch) */
			.site-search {
				position: relative;
				width: 200px;
			}

			:global(.site-search-input) {
				width: 100%;
				padding: var(--space-2) var(--space-3);
				font-family: var(--font-sans);
				font-size: var(--text-sm);
				color: var(--text-body);
				background: var(--surface-card);
				border: var(--border-hairline) solid var(--border);
				border-radius: var(--radius-md);
				transition:
					border-color var(--dur-fast) var(--ease-out),
					box-shadow var(--dur-fast) var(--ease-out);
			}

			:global(.site-search-input)::placeholder {
				color: var(--text-faint);
			}

			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border-color: var(--accent);
				box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
			}

			:global(.site-search-results) {
				position: absolute;
				top: calc(100% + var(--space-2));
				left: 0;
				right: 0;
				background: var(--surface-card);
				border: var(--border-hairline) solid var(--border);
				border-radius: var(--radius-md);
				box-shadow: var(--shadow-md);
				max-height: 400px;
				overflow-y: auto;
				z-index: 1000;
			}

			:global(.site-search-results .emdash-live-search-loading),
			:global(.site-search-results .emdash-live-search-no-results) {
				padding: var(--space-4);
				text-align: center;
				color: var(--text-faint);
				font-family: var(--font-sans);
				font-size: var(--text-sm);
			}

			:global(.site-search-result) {
				display: block;
				padding: var(--space-3) var(--space-4);
				text-decoration: none;
				color: var(--text-body);
				border-bottom: var(--border-hairline) solid var(--border);
				transition: background var(--dur-fast) var(--ease-out);
			}

			:global(.site-search-result):last-child {
				border-bottom: none;
			}

			:global(.site-search-result):hover,
			:global(.site-search-result):focus,
			:global(.site-search-result.focused) {
				background: var(--surface-raised);
				outline: none;
			}

			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-family: var(--font-sans);
				font-weight: var(--weight-medium);
				font-size: var(--text-sm);
			}

			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				color: var(--text-faint);
				text-transform: uppercase;
				letter-spacing: var(--tracking-label);
				margin-top: 2px;
			}

			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				font-size: var(--text-sm);
				color: var(--text-muted);
				margin-top: var(--space-1);
				line-height: var(--leading-snug);
			}

			:global(.site-search-result .emdash-live-search-result-snippet mark) {
				background: color-mix(in srgb, var(--accent) 18%, transparent);
				color: var(--text-strong);
			}

			/* Theme toggle (shows the current preference) */
			.theme-toggle {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 38px;
				height: 38px;
				border-radius: var(--radius-md);
				border: var(--border-hairline) solid var(--border);
				background: transparent;
				color: var(--text-muted);
				cursor: pointer;
				transition:
					background var(--dur-fast) var(--ease-out),
					color var(--dur-fast) var(--ease-out);
			}

			.theme-toggle:hover {
				background: var(--accent-soft);
				color: var(--accent);
			}

			.theme-toggle svg {
				display: none;
			}
			/* Default to the system icon before JS sets data-theme-pref (no-JS too) */
			.theme-toggle .ic-monitor {
				display: block;
			}
			:global(:root[data-theme-pref="light"]) .theme-toggle .ic-monitor,
			:global(:root[data-theme-pref="dark"]) .theme-toggle .ic-monitor {
				display: none;
			}
			:global(:root[data-theme-pref="light"]) .theme-toggle .ic-sun {
				display: block;
			}
			:global(:root[data-theme-pref="dark"]) .theme-toggle .ic-moon {
				display: block;
			}

			/* ---------------- Main ---------------- */
			main {
				min-height: calc(100vh - var(--header-height) - 240px);
			}

			/* ---------------- Footer ---------------- */
			.site-footer {
				background: var(--bg-deep);
				border-top: var(--border-hairline) solid var(--border);
				margin-top: var(--space-9);
			}

			.footer-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--space-8) var(--space-6);
				display: flex;
				gap: var(--space-7);
				flex-wrap: wrap;
				align-items: flex-start;
			}

			.footer-about {
				flex: 1 1 320px;
				display: flex;
				gap: var(--space-4);
				align-items: flex-start;
			}

			.footer-about-title {
				font-family: var(--font-serif);
				font-weight: var(--weight-heading);
				font-size: var(--text-lg);
				color: var(--text-strong);
				margin: 0;
			}

			.footer-bio {
				font-family: var(--font-serif);
				font-size: var(--text-base);
				line-height: 1.7;
				color: var(--text-muted);
				margin: var(--space-2) 0 var(--space-4);
				max-width: 440px;
			}

			.footer-nav {
				flex: 0 0 auto;
				display: flex;
				flex-direction: column;
				gap: var(--space-2);
				font-family: var(--font-sans);
				font-size: var(--text-sm);
			}

			.footer-nav-label {
				text-transform: uppercase;
				letter-spacing: var(--tracking-label);
				font-weight: var(--weight-heading);
				color: var(--text-muted);
				margin: 0 0 var(--space-1);
			}

			.footer-nav a {
				color: var(--text-muted);
				text-decoration: none;
			}

			.footer-nav a:hover {
				color: var(--accent);
			}

			/* Footer widget area (EmDash widgets) */
			.footer-widgets {
				flex: 0 1 auto;
			}

			.footer-widgets :global(.widget-area) {
				display: flex;
				flex-direction: column;
				gap: var(--space-5);
			}

			.footer-widgets :global(.widget__title) {
				font-family: var(--font-sans);
				font-size: var(--text-sm);
				text-transform: uppercase;
				letter-spacing: var(--tracking-label);
				font-weight: var(--weight-heading);
				color: var(--text-muted);
				margin: 0 0 var(--space-2);
			}

			.footer-widgets :global(.widget__content) {
				font-family: var(--font-sans);
				font-size: var(--text-sm);
				color: var(--text-muted);
				line-height: 1.7;
			}

			.footer-bottom {
				border-top: var(--border-hairline) solid var(--border);
			}

			.footer-bottom-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--space-4) var(--space-6);
				display: flex;
				justify-content: space-between;
				gap: var(--space-3);
				flex-wrap: wrap;
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				color: var(--text-faint);
			}

			.footer-bottom-inner a {
				color: var(--text-muted);
			}

			@media (max-width: 760px) {
				.header-inner {
					flex-wrap: wrap;
					padding: var(--space-3) var(--space-4);
					gap: var(--space-3);
				}

				.site-nav {
					gap: var(--space-4);
					flex-wrap: wrap;
				}

				.nav-list {
					gap: var(--space-4);
					flex-wrap: wrap;
				}

				.site-search {
					width: 100%;
					order: 3;
				}
			}
		</style>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
